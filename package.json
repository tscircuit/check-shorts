{
  "name": "@tscircuit/check-shorts",
  "version": "0.0.10",
  "license": "MIT",
  "type": "module",
  "description": "Detect unintended shorts between named nets",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tscircuit/check-shorts.git"
  },
  "bugs": {
    "url": "https://github.com/tscircuit/check-shorts/issues"
  },
  "homepage": "https://github.com/tscircuit/check-shorts#readme",
  "scripts": {
    "build": "bun run typecheck && tsc -p tsconfig.build.json && bun build lib/index.ts --outdir dist --target=node --format=esm --packages=external",
    "smoke:downstream": "bun test tests/downstream-import-smoke.test.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tscircuit/circuit-json-util": "^0.0.99",
    "@tscircuit/image-utils": "^0.0.8",
    "@tscircuit/math-utils": "^0.0.36",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "circuit-json-to-connectivity-map": "^0.0.23",
    "circuit-json-to-gerber": "^0.0.79",
    "circuit-json": "^0.0.446",
    "circuit-to-canvas": "^0.0.110",
    "circuit-to-svg": "^0.0.378",
    "fast-png": "^8.0.0",
    "gerber-to-svg": "^4.2.8",
    "looks-same": "^9.0.1",
    "react": "^19.2.7",
    "tscircuit": "^0.0.2044",
    "transformation-matrix": "^2.16.1",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tscircuit/circuit-json-util": "*",
    "@tscircuit/math-utils": "*",
    "circuit-json-to-connectivity-map": "*",
    "circuit-json-to-gerber": "*",
    "circuit-json": "*",
    "circuit-to-canvas": "*",
    "circuit-to-svg": "*",
    "fast-png": "^8.0.0",
    "gerber-to-svg": "*",
    "react": "^19.2.7",
    "transformation-matrix": "^2.16.1",
    "typescript": "^5"
  }
}
