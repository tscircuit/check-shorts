{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun", "node"],
    "paths": {
      "lib/*": ["./lib/*"],
      "tests/*": ["./tests/*"]
    }
  },
  "include": ["lib", "tests"]
}
